@model HTKTX.Models.DormRegistrationViewModel

@{
    ViewData["Title"] = "Đăng ký Ký túc xá";
}

<div class="container mt-5">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-header bg-primary text-white rounded-top-4">
            <h2 class="mb-0"><i class="bi bi-building"></i> Đăng ký Ký túc xá</h2>
        </div>
        <div class="card-body p-4">
            <form asp-action="Register" enctype="multipart/form-data" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CCCD" class="form-label">CCCD</label>
                        <input asp-for="CCCD" class="form-control shadow-sm" />
                        <span asp-validation-for="CCCD" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control shadow-sm" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="FullName" class="form-label">Họ và tên</label>
                        <input asp-for="FullName" class="form-control shadow-sm" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="Gender" class="form-label">Giới tính</label>
                        <select asp-for="Gender" class="form-select shadow-sm">
                            <option value="">Chọn giới tính</option>
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                            <option value="Khác">Khác</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Phone" class="form-label">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control shadow-sm" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="DateOfBirth" class="form-label">Ngày sinh</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control shadow-sm" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="RoomTypeId" class="form-label">Loại phòng</label>
                        <select asp-for="RoomTypeId" class="form-select shadow-sm"
                                asp-items="@(new SelectList(ViewBag.RoomTypes, "RoomTypeId", "Name"))">
                            <option value="">Chọn loại phòng</option>
                        </select>
                        <span asp-validation-for="RoomTypeId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="RoomNumber" class="form-label">Số phòng</label>
                        <select asp-for="RoomNumber" class="form-select shadow-sm"
                                asp-items="@(new SelectList(ViewBag.Rooms, "RoomNumber", "RoomNumber"))">
                            <option value="">Chọn số phòng</option>
                        </select>
                        <span asp-validation-for="RoomNumber" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CCCDFrontImage" class="form-label">Ảnh CCCD Mặt Trước</label>
                        <input asp-for="CCCDFrontImage" type="file" accept="image/*" class="form-control shadow-sm" />
                        <span asp-validation-for="CCCDFrontImage" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CCCDBackImage" class="form-label">Ảnh CCCD Mặt Sau</label>
                        <input asp-for="CCCDBackImage" type="file" accept="image/*" class="form-control shadow-sm" />
                        <span asp-validation-for="CCCDBackImage" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="StartDate" class="form-label">Ngày bắt đầu</label>
                        <input asp-for="StartDate" type="date" class="form-control shadow-sm" />
                        <span asp-validation-for="StartDate" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="EndDate" class="form-label">Ngày kết thúc (tùy chọn)</label>
                        <input asp-for="EndDate" type="date" class="form-control shadow-sm" />
                        <span asp-validation-for="EndDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success btn-lg px-4 shadow">
                        <i class="bi bi-send-check"></i> Gửi Đăng ký
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
