@model IEnumerable<UserWithRolesViewModel>

@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<!-- Font Awesome để có icon -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<h2 class="mb-4"><i class="fas fa-users-cog me-2"></i>@ViewData["Title"]</h2>

<p>
    <a asp-action="AddUser" class="btn btn-success mb-3">
        <i class="fas fa-user-plus me-1"></i> Thêm tài khoản
    </a>
</p>

<table class="table table-hover table-bordered shadow-sm">
    <thead class="table-light">
        <tr>
            <th><i class="fas fa-envelope me-1"></i> Email</th>
            <th><i class="fas fa-user-tag me-1"></i> Vai trò</th>
            <th class="text-center"><i class="fas fa-cogs me-1"></i> Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
                <tr>
                    <td>@item.User.Email</td>
                    <td>
                    @if (item.Roles.Any())
                    {
                        @foreach (var role in item.Roles)
                        {
                                        <span class="badge bg-primary me-1">@role</span>
                        }
                    }
                    else
                    {
                                <span class="text-muted">Chưa có</span>
                    }
                    </td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@item.User.Id" class="btn btn-sm btn-outline-info me-1">
                            <i class="fas fa-eye"></i>
                        </a>
                        <a asp-action="EditRoles" asp-route-userId="@item.User.Id" class="btn btn-sm btn-outline-warning me-1">
                            <i class="fas fa-user-shield"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.User.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Bạn có chắc muốn xóa tài khoản này không?');">
                            <i class="fas fa-trash-alt"></i>
                        </a>
                    </td>
                </tr>
        }
    </tbody>
</table>
