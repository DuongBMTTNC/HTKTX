@model IEnumerable<HTKTX.Models.Room>

@{
    ViewData["Title"] = "Danh sách phòng";
}

<!-- Font Awesome để dùng icon -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<h2 class="mb-4"><i class="fas fa-door-open me-2"></i>Danh sách phòng</h2>

<div class="mb-3 d-flex gap-2">
    <a asp-action="Create" class="btn btn-success"><i class="fas fa-plus-circle me-1"></i> Thêm phòng</a>
    <a asp-controller="RoomTypes" asp-action="Index" class="btn btn-secondary"><i class="fas fa-list me-1"></i> Danh mục phòng</a>
</div>

<form asp-action="SearchRoomByNumber" method="get" class="row g-2 mb-4">
    <div class="col-auto">
        <input type="text" name="roomNumber" class="form-control" placeholder="Nhập số phòng" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary"><i class="fas fa-search me-1"></i> Tìm</button>
    </div>
</form>

@if (TempData["Error"] != null)
{
        <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var item in Model)
    {
            <div class="col">
                <div class="card shadow-sm border-primary h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="fas fa-door-closed me-1"></i> Phòng: <strong>@item.RoomNumber</strong>
                        </h5>
                        <p class="card-text mb-1"><i class="fas fa-venus-mars me-1"></i> Giới tính: @item.Gender</p>
                        <p class="card-text mb-1">
                            <i class="fas fa-users me-1"></i> Số người ở: @item.CurrentOccupants / @item.RoomType?.NumberOfBeds
                        </p>
                        <p class="card-text"><i class="fas fa-tag me-1"></i> Loại phòng: @item.RoomType?.Name</p>
                    </div>
                    <div class="card-footer bg-white border-top-0 d-flex justify-content-between">
                        <a asp-action="Details" asp-route-id="@item.RoomNumber" class="btn btn-outline-info btn-sm">
                            <i class="fas fa-eye"></i> Xem
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.RoomNumber" class="btn btn-outline-warning btn-sm">
                            <i class="fas fa-edit"></i> Sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.RoomNumber" class="btn btn-outline-danger btn-sm">
                            <i class="fas fa-trash-alt"></i> Xoá
                        </a>
                    </div>
                </div>
            </div>
    }
</div>
