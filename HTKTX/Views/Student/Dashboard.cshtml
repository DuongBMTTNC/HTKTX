@{
    ViewData["Title"] = "Dashboard";
}
<style>
    body {
        background-color: #e0f0ff;
    }

    .sidebar {
        width: 250px;
        background-color: #1e1e2f;
        color: white;
        transition: all 0.3s;
        min-height: 100vh;
        position: relative;
    }

    .sidebar.collapsed {
        width: 80px;
    }

    .sidebar .nav-link {
        color: #ccc;
        padding: 12px;
        display: flex;
        align-items: center;
        gap: 10px;
        border-radius: 8px;
        transition: background-color 0.2s;
        white-space: nowrap;
    }

    .sidebar .nav-link:hover {
        background-color: #2c2c3c;
        color: white;
    }

    .sidebar .nav-link i {
        font-size: 1.2rem;
    }

    .sidebar .nav-link span {
        transition: opacity 0.2s, transform 0.2s;
    }

    .sidebar.collapsed .nav-link span {
        opacity: 0;
        transform: translateX(-10px);
        pointer-events: none;
    }

    .content-area {
        margin-left: 250px;
        transition: all 0.3s;
        padding: 20px;
        flex-grow: 1;
    }

    .content-area.full-width {
        margin-left: 80px;
    }

    .sidebar-toggle {
        position: absolute;
        top: 10px;
        right: -25px;
        background-color: #1e1e2f;
        border: none;
        color: white;
        padding: 6px 8px;
        border-radius: 50%;
        cursor: pointer;
    }

    .sidebar-footer {
        position: absolute;
        bottom: 10px;
        width: 100%;
        padding: 10px;
        color: #aaa;
        font-size: 0.875rem;
    }
</style>

<div class="d-flex">
    <!-- Sidebar -->
    <div id="sidebar" class="sidebar">
        <button class="sidebar-toggle" id="toggleSidebar">
            <i class="bi bi-list"></i>
        </button>
        <h5 class="p-3 mb-0">
            <i class="bi bi-house-door-fill"></i>
            <span class="sidebar-label">Hệ thống KTX</span>
        </h5>

        <div class="nav flex-column px-2 mt-3">
            <a asp-controller="StudentProfiles" asp-action="Profile" class="nav-link">
                <i class="bi bi-person-circle"></i> <span>Thông tin cá nhân</span>
            </a>
            <a asp-controller="StudentProfiles" asp-action="DormInfo" class="nav-link">
                <i class="bi bi-info-circle"></i> <span>Thông tin lưu trú</span>
            </a>
            <a asp-controller="RepairRequests" asp-action="MyRequests" class="nav-link">
                <i class="bi bi-tools"></i> <span>Báo hỏng / Sửa chữa</span>
            </a>
            <a asp-controller="RentalBills" asp-action="Index" class="nav-link">
                <i class="bi bi-receipt"></i> <span>Hóa đơn thuê</span>
            </a>
            <a asp-controller="WaterElectricBills" asp-action="StudentIndex" class="nav-link">
                <i class="bi bi-lightning-charge"></i> <span>Hóa đơn điện nước</span>
            </a>
            <a asp-controller="RoomChangeRequests" asp-action="Index" class="nav-link">
                <i class="bi bi-arrow-left-right"></i> <span>Yêu cầu đổi phòng</span>
            </a>
            <a asp-controller="Notifications" asp-action="Index" class="nav-link" data-title="Thong bao">
                <i class="bi bi-question-circle"></i> <span>Thong bao</span>
            </a>
            <a asp-controller="Posts" asp-action="Index" class="nav-link">
                <i class="bi bi-chat-dots"></i> <span>Tương tác</span>
            </a>
        </div>

        <div class="sidebar-footer text-center">
            <i class="bi bi-envelope-at"></i> admin@ktx.com
        </div>
    </div>

    <!-- Main Content -->
    <div id="contentArea" class="content-area">
    <h2 class="text-center mb-4">Trang chính của sinh viên</h2>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col">
            <a asp-controller="StudentProfiles" asp-action="Profile" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-person-circle fs-1 text-primary"></i>
                        <h5 class="card-title mt-2">Thông tin cá nhân</h5>
                        <p class="card-text text-muted">Xem và cập nhật hồ sơ sinh viên</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col">
            <a asp-controller="StudentProfiles" asp-action="DormInfo" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-info-circle fs-1 text-success"></i>
                        <h5 class="card-title mt-2">Thông tin lưu trú</h5>
                        <p class="card-text text-muted">Xem phòng ở và lịch sử nội trú</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col">
            <a asp-controller="RepairRequests" asp-action="Create" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-tools fs-1 text-warning"></i>
                        <h5 class="card-title mt-2">Báo hỏng / Sửa chữa</h5>
                        <p class="card-text text-muted">Gửi yêu cầu sửa chữa thiết bị</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col">
            <a asp-controller="RentalBills" asp-action="Index" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-receipt fs-1 text-danger"></i>
                        <h5 class="card-title mt-2">Hóa đơn thuê</h5>
                        <p class="card-text text-muted">Xem các hóa đơn thuê phòng</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col">
            <a asp-controller="WaterElectricBills" asp-action="StudentIndex" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-lightning-charge fs-1 text-info"></i>
                        <h5 class="card-title mt-2">Hóa đơn điện nước</h5>
                        <p class="card-text text-muted">Theo dõi hóa đơn điện, nước</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col">
            <a asp-controller="RoomChangeRequests" asp-action="Index" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-arrow-left-right fs-1 text-secondary"></i>
                        <h5 class="card-title mt-2">Yêu cầu đổi phòng</h5>
                        <p class="card-text text-muted">Gửi yêu cầu đổi sang phòng khác</p>
                    </div>
                </div>
            </a>
        </div>

        <div class="col">
            <a asp-controller="Notifications" asp-action="Index" class="text-decoration-none">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-bell fs-1 text-dark"></i>
                        <h5 class="card-title mt-2">Thông báo</h5>
                        <p class="card-text text-muted">Xem các thông báo từ hệ thống</p>
                    </div>
                </div>
            </a>
        </div>
    </div>
</div>

</div>

<script>
    const sidebar = document.getElementById("sidebar");
    const contentArea = document.getElementById("contentArea");
    const toggleBtn = document.getElementById("toggleSidebar");

    toggleBtn.addEventListener("click", () => {
        sidebar.classList.toggle("collapsed");
        contentArea.classList.toggle("full-width");
    });
</script>
