@model HTKTX.Models.DormRegistration
@{
    ViewData["Title"] = "Thông tin lưu trú";
}

<h4 class="mb-3"><i class="bi bi-info-circle"></i> Thông tin lưu trú</h4>

<div class="card shadow-sm mx-auto" style="max-width: 500px;">
    <div class="card-body p-4">

        <div class="mb-3">
            <i class="bi bi-door-open me-2"></i> <strong>Loại phòng:</strong><br />
            <span class="text-muted">
                @Model.RoomType?.Name (@Model.RoomType?.NumberOfBeds giường)
            </span>
        </div>

        <div class="mb-3">
            <i class="bi bi-building me-2"></i> <strong>Số phòng:</strong><br />
            <span class="text-muted">@Model.RoomNumber</span>
        </div>

        <div class="mb-3">
            <i class="bi bi-calendar-check me-2"></i> <strong>Ngày bắt đầu:</strong><br />
            <span class="text-muted">@Model.StartDate.ToString("dd/MM/yyyy")</span>
        </div>

        <div class="mb-2">
            <i class="bi bi-calendar-x me-2"></i> <strong>Ngày kết thúc:</strong><br />
            <span class="text-muted">@Model.EndDate.ToString("dd/MM/yyyy")</span>
        </div>

    </div>
</div>
