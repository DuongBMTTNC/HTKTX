@model RoomType
@{
    ViewData["Title"] = "Thêm loại phòng";
}

<h2>@ViewData["Title"]</h2>
<form asp-action="Create">
    <div class="form-group">
        <label asp-for="RoomTypeId"></label>
        <input asp-for="RoomTypeId" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="NumberOfBeds"></label>
        <input asp-for="NumberOfBeds" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Facilities"></label>
        <input asp-for="Facilities" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Price"></label>
        <textarea asp-for="Price" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
