@model List<HTKTX.Models.Notification>
@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager

@{
    ViewData["Title"] = "Thông báo";
    var isAdmin = User.IsInRole("Admin");
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Thông báo của bạn</h2>
    @if (isAdmin)
    {
                <a class="btn btn-primary" asp-action="CreateForStudents">
                    <i class="bi bi-bell"></i> Tạo thông báo cho sinh vien
            </a>
    }
</div>

@if (!Model.Any())
{
        <div class="alert alert-info">
            Bạn chưa có thông báo nào.
        </div>
}
else
{
        <div class="list-group">
        @foreach (var item in Model)
        {
                    <div class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@item.Message</strong>
                            <div class="text-muted small">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                        </div>
                        <div>
                    @if (!item.IsRead)
                    {
                                    <form asp-action="MarkAsRead" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-success">
                                            <i class="bi bi-check2-circle"></i> Đánh dấu đã đọc
                                        </button>
                                    </form>
                    }
                            
                        </div>
                    </div>
        }
        </div>
}
